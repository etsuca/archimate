<% set_meta_tags title: t('.title') %>
<div class="bg-white">
  <div class="mx-auto max-w-screen-2xl px-4 md:px-8 pb-6 md:pb-12">
    <h2 class="py-12 md:py-24 text-base md:text-xl text-center"><%= t('.title') %></h2>
    <%= render 'search_form', url: buildings_path %>
    <div class="building-container">
      <% if @buildings.present? %>
        <div class="grid gap-6 sm:grid-cols-2 mb-6">
          <%= render @buildings %>
        </div>
      <% else %>
        <p><%= t('.no_result') %></p>
      <% end %>
      <div class="pagination">
        <% if @buildings_size > 10 %>
          <%= link_to 'もっとみる', buildings_path, class: 'more-button text-xs md:text-base', data: { page: @buildings.next_page } %>
        <% end %>
      </div>
    </div>
  </div>
</div>
