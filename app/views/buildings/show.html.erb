<% if @building.present? %>
  <% set_meta_tags title: t('.title', building_name: @building.name) %>
  <div class="flex flex-col h-screen md:flex-row items-end">
    <div class="w-full md:w-3/4 h-full relative">
      <%= render 'shared/building', building: @building %>
    </div>
    <div class="w-full md:w-144 px-4 md:pt-0 pt-4">
      <h1 class="text-3xl md:text-5xl mb-4"><%= @building.name %></h1>
      <div class="relative">
        <%= link_to "https://maps.google.com/maps?q=#{@building.location}", target: :_blank, rel: "noopener noreferrer" do %>
          <div class="flex items-center hover:drop-shadow-lg">
            <p class="mr-2"><i class="fa-solid fa-location-dot"></i></p>
            <%= simple_format(@building.pref + @building.location) %>
          </div>
        <% end %>
        <div class="md:static bottom-5 w-full text-white">
          <div class="flex flex-row-reverse md:flex-col mt-8 mb-28 text-center justify-center items-center">
            <% if @building.by?(current_user) %>
              <%= link_to edit_building_path(@building), method: :get, class: 'flex items-center justify-center bg-third border border-first text-first h-14 w-14 md:h-fit md:w-full md:mb-8 mx-6 rounded-full hover:scale-105 hover:drop-shadow-lg cursor-pointer' do %>
                <i class="fa-regular fa-pen-to-square fa-xl md:text-sm md:mr-2"></i>
                <div class="hidden md:block">
                  <p>Edit</p>
                </div>
              <% end %>
              <%= link_to building_path(@building), method: :delete, data: { confirm: t('defaults.message.destroy_confirm') }, class: 'flex items-center justify-center bg-seventh border border-seventh h-14 w-14 md:w-full mx-6 md:h-fit rounded-full hover:scale-105 hover:drop-shadow-lg cursor-pointer' do %>
                <i class="fa-regular fa-trash-can fa-xl md:text-sm md:mr-2"></i>
                <div class="hidden md:block">
                  <p>Delete</p>
                </div>
              <% end %>
            <% else %>
              <%= render 'shared/like_nope_button', building: @building %>
              <%= link_to check_in_buildings_path(name: @building.name, pref: @building.pref, location: @building.location, open_range: @building.open_range, experience: @building.experience, architect: @building.architect), method: :get, class: 'flex items-center justify-center bg-third border border-first text-first h-14 w-14 md:h-fit mx-6 md:w-full rounded-full hover:scale-105 hover:drop-shadow-lg cursor-pointer' do %>
                <i class="fa-solid fa-check fa-xl md:text-sm md:mr-2"></i>
                <div class="hidden md:block">
                  <p>Check in</p>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
<% else %>
  <p><%= t('.no_result') %></p>
<% end %>
